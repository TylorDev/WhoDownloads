{
  "name": "whodownloads",
  "productName": "WhoDownloads",
  "version": "1.1.2",
  "description": "WhoDownloads desktop app",
  "author": "TylorDev",
  "homepage": "https://github.com/TylorDev/WhoDownloads",
  "repository": {
    "type": "git",
    "url": "https://github.com/TylorDev/WhoDownloads.git"
  },
  "bugs": {
    "url": "https://github.com/TylorDev/WhoDownloads/issues"
  },
  "updates": {
    "url": "https://github.com/TylorDev/WhoDownloads/releases"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:debug": "node scripts/dev.mjs --remote-debugging-port=9222",
    "prepare:node": "node scripts/prepare-node-runtime.mjs",
    "build": "electron-vite build",
    "pack:win": "npm run prepare:node && npm run build && electron-builder --win --dir",
    "dist:win": "npm run prepare:node && npm run build && electron-builder --win",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "sass": "^1.100.0",
    "sass-embedded": "^1.100.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "io.github.tylordev.whodownloads",
    "productName": "WhoDownloads",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin/win",
        "to": "bin/win",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/icons/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhoDownloads"
    }
  }
}
